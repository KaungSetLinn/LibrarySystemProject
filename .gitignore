# =============================================================================
# .gitignore for Toyoda v3.0.6 Reference Environment
# 目的: 機密情報・個人情報・環境固有ファイル・肥大ファイルを GitHub に
#       誤って push しないための包括的除外設定。
# 作成: 2026-05-12 / Y.Toyoda
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 機密情報・認証情報(最優先で除外)
# -----------------------------------------------------------------------------
# 環境変数ファイル全般。DB パスワード、セッションシークレット、API キー等を含む。
.env
.env.*
!.env.example
*.env
env.local
env.development
env.production

# ngrok の認証トークンや設定
ngrok.yml
ngrok.exe
.ngrok2/
ngrok-*.zip

# クラウド認証情報
.aws/
.gcp/
credentials.json
service-account*.json
*_credentials.json
*_secret*.json
*.pem
*.key
*.cer
*.crt
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# GitHub Personal Access Token などをうっかり書き出したメモ
*token*.txt
*secret*.txt
*password*.txt
PAT.txt

# -----------------------------------------------------------------------------
# 2. データベース実体(個人情報を含むため絶対公開しない)
# -----------------------------------------------------------------------------
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
*.sqlite-journal
library.db
library2.db
server/data/*.db
server/data/*.sqlite
data/*.db
data/*.sqlite

# DB ダンプ
*.dump
*.bak
*.sql.bak
backup_*.sql

# -----------------------------------------------------------------------------
# 3. node_modules とパッケージ管理の肥大ファイル
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/
jspm_packages/
bower_components/

# package-lock は通常残すが、用途に応じて。残す方針なら下記2行は削除可。
# package-lock.json
# yarn.lock

# -----------------------------------------------------------------------------
# 4. ログファイル
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
server.log
access.log
error.log
debug.log
nohup.out

# -----------------------------------------------------------------------------
# 5. ビルド成果物・キャッシュ
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.eslintcache
.tsbuildinfo
*.tsbuildinfo
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# 6. OS 固有ファイル
# -----------------------------------------------------------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# 7. エディタ・IDE 固有ファイル
# -----------------------------------------------------------------------------
# VSCode
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json.example
*.code-workspace

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*.swn
*~
.*.sw?
\#*\#
.\#*

# Sublime
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# 8. 一時ファイル・テスト出力
# -----------------------------------------------------------------------------
tmp/
temp/
.tmp/
*.tmp
*.temp
*.pid
*.seed
*.pid.lock
test-results/
test-output/
*.test.local.*

# -----------------------------------------------------------------------------
# 9. Windows 固有のローカルパス痕跡(コミット混入防止)
# -----------------------------------------------------------------------------
# 豊田の WSL 側ホームディレクトリ参照や Windows 絶対パスを含むメモ
local-paths.txt
my-notes-private.md
*.local.md

# -----------------------------------------------------------------------------
# 10. 配布用 ZIP・アーカイブ(公開不要)
# -----------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
# ただし配布用パッケージはコミットしたい場合があるため、
# 個別に許可するには下のように指定:
# !releases/library-reservation-system-v3.0.6-final.zip

# -----------------------------------------------------------------------------
# 11. ローカル設定の上書き(library-system-config.txt のローカル版)
# -----------------------------------------------------------------------------
library-system-config.local.txt
library-system-config.*.local.txt
config.local.json

# -----------------------------------------------------------------------------
# 12. AI 系・解析ツールの中間ファイル
# -----------------------------------------------------------------------------
.copilot/
.cursor/
.windsurf/
*.context.json

# -----------------------------------------------------------------------------
# 13. プロジェクト固有(豊田 v3.0.6 由来の保持不要ファイル)
# -----------------------------------------------------------------------------
# 監査ログのローカル書出
library_local_*.json
library_bridge_*.txt

# 議事録の下書き
*議事録*.docx.draft
*draft*.docx
~$*.docx
~$*.xlsx
~$*.pptx

# 自動生成バックアップ
*.bak
*.orig
*.rej
*.swp
